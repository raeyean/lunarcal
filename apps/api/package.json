{
  "name": "@lunarcal/api",
  "version": "1.0.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/index.js --external:firebase-functions --external:firebase-admin --alias:@lunarcal/shared=../../packages/shared/src/index.ts",
    "build:watch": "npm run build -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^0.19.10",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "firebase-admin": "^13.0.0",
    "hono": "^4.7.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.6"
  }
}
