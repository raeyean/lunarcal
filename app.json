{
  "expo": {
    "name": "LunarCal",
    "slug": "LunarCal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f3ec",
      "dark": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0e0d0b"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raeyean.LunarCal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "./plugins/withWidget",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#a02617"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e9499a56-d37a-40d2-b1a9-4a1793c8d7dd"
      }
    },
    "owner": "raeyean"
  }
}
