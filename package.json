{
  "name": "lunarcal",
  "version": "1.0.0",
  "main": "index.ts",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:api": "npm run build -w @lunarcal/api",
    "dev:api": "npm run build:watch -w @lunarcal/api",
    "emulator": "npm run build:api && firebase emulators:start --only functions",
    "test": "npm run test -w @lunarcal/api && npm run test -w @lunarcal/shared"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@tanstack/react-query": "^5.100.10",
    "expo": "~54.0.33",
    "expo-background-fetch": "~14.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-task-manager": "~14.0.9",
    "lunar-javascript": "^1.7.7",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "^15.13.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
